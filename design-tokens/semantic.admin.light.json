{
  "$description": "SLT Design Tokens — Tier 2: Semantic(Admin / ライトモード)。AI-Dash 管理画面用。コーポレートダーク系とは意図的に分離。",
  "color": {
    "surface": {
      "primary":   { "$type": "color", "$value": "{color.gray.50}",  "$description": "ページ背景 #F8FAFC" },
      "secondary": { "$type": "color", "$value": "{color.gray.0}",   "$description": "カード / サーフェス #FFFFFF" },
      "tertiary":  { "$type": "color", "$value": "{color.gray.100}", "$description": "ホバー面 #F1F5F9" },
      "brand":     { "$type": "color", "$value": "{color.blue.800}" },
      "inverse":   { "$type": "color", "$value": "{color.gray.900}" },
      "overlay":   { "$type": "color", "$value": "{color.alpha.slate-60}" }
    },
    "text": {
      "primary":   { "$type": "color", "$value": "{color.gray.900}" },
      "secondary": { "$type": "color", "$value": "{color.gray.600}" },
      "disabled":  { "$type": "color", "$value": "{color.gray.400}" },
      "inverse":   { "$type": "color", "$value": "{color.gray.0}" },
      "link":      { "$type": "color", "$value": "{color.blue.800}" },
      "link-hover": { "$type": "color", "$value": "{color.blue.600}" },
      "brand":     { "$type": "color", "$value": "{color.blue.800}" }
    },
    "border": {
      "default": { "$type": "color", "$value": "{color.gray.200}" },
      "strong":  { "$type": "color", "$value": "{color.gray.300}" },
      "focus":   { "$type": "color", "$value": "{color.blue.600}" }
    },
    "action": {
      "primary":         { "$type": "color", "$value": "{color.blue.800}" },
      "primary-hover":   { "$type": "color", "$value": "{color.blue.600}" },
      "primary-active":  { "$type": "color", "$value": "{color.blue.700}" },
      "secondary":       { "$type": "color", "$value": "{color.blue.500}" },
      "secondary-hover": { "$type": "color", "$value": "{color.blue.600}" }
    },
    "feedback": {
      "success":            { "$type": "color", "$value": "{color.emerald.500}" },
      "success-surface":    { "$type": "color", "$value": "{color.green.100}" },
      "success-on-surface": { "$type": "color", "$value": "{color.emerald.500}" },
      "warning":            { "$type": "color", "$value": "{color.amber.500}" },
      "warning-surface":    { "$type": "color", "$value": "{color.amber.100}" },
      "warning-on-surface": { "$type": "color", "$value": "{color.amber.500}" },
      "danger":             { "$type": "color", "$value": "{color.red.500}" },
      "danger-surface":     { "$type": "color", "$value": "{color.red.100}" },
      "danger-on-surface":  { "$type": "color", "$value": "{color.red.500}" },
      "info":               { "$type": "color", "$value": "{color.blue.500}" },
      "info-surface":       { "$type": "color", "$value": "{color.blue.50}" },
      "info-on-surface":    { "$type": "color", "$value": "{color.blue.500}" }
    },
    "interactive": {
      "hover":  { "$type": "color", "$value": "{color.gray.100}" },
      "active": { "$type": "color", "$value": "{color.gray.200}" }
    }
  },
  "typography": {
    "display": {
      "$type": "typography",
      "$value": { "fontFamily": "{font.family.admin}", "fontSize": "{font.size.2xl}", "fontWeight": "{font.weight.bold}", "lineHeight": "{font.lineHeight.tight}" }
    },
    "heading-1": {
      "$type": "typography",
      "$value": { "fontFamily": "{font.family.admin}", "fontSize": "{font.size.xl}", "fontWeight": "{font.weight.bold}", "lineHeight": "{font.lineHeight.tight}" }
    },
    "heading-2": {
      "$type": "typography",
      "$value": { "fontFamily": "{font.family.admin}", "fontSize": "{font.size.lg}", "fontWeight": "{font.weight.bold}", "lineHeight": "{font.lineHeight.tight}" }
    },
    "heading-3": {
      "$type": "typography",
      "$value": { "fontFamily": "{font.family.admin}", "fontSize": "{font.size.md}", "fontWeight": "{font.weight.medium}", "lineHeight": "{font.lineHeight.base}" }
    },
    "body": {
      "$type": "typography",
      "$value": { "fontFamily": "{font.family.admin}", "fontSize": "{font.size.md}", "fontWeight": "{font.weight.regular}", "lineHeight": "{font.lineHeight.base}" }
    },
    "body-small": {
      "$type": "typography",
      "$value": { "fontFamily": "{font.family.admin}", "fontSize": "{font.size.sm}", "fontWeight": "{font.weight.regular}", "lineHeight": "{font.lineHeight.base}" }
    },
    "caption": {
      "$type": "typography",
      "$value": { "fontFamily": "{font.family.admin}", "fontSize": "{font.size.xs}", "fontWeight": "{font.weight.regular}", "lineHeight": "{font.lineHeight.tight}" }
    },
    "code": {
      "$type": "typography",
      "$value": { "fontFamily": "{font.family.mono}", "fontSize": "{font.size.sm}", "fontWeight": "{font.weight.regular}", "lineHeight": "{font.lineHeight.base}" }
    }
  },
  "focus": {
    "ring-width":  { "$type": "dimension", "$value": { "value": 2, "unit": "px" } },
    "ring-offset": { "$type": "dimension", "$value": { "value": 2, "unit": "px" } }
  },
  "space": {
    "$description": "レイアウト余白。全 theme 共通値（primitives.space の薄いラッパー）。",
    "xs": { "$type": "dimension", "$value": "{space.1}" },
    "sm": { "$type": "dimension", "$value": "{space.2}" },
    "md": { "$type": "dimension", "$value": "{space.4}" },
    "lg": { "$type": "dimension", "$value": "{space.6}" },
    "xl": { "$type": "dimension", "$value": "{space.8}" },
    "2xl": { "$type": "dimension", "$value": "{space.12}" }
  },
  "shape": {
    "$description": "角の形状。全 theme 共通値（primitives.radius の薄いラッパー）。",
    "radius-sm": { "$type": "dimension", "$value": "{radius.sm}" },
    "radius-md": { "$type": "dimension", "$value": "{radius.md}" },
    "radius-lg": { "$type": "dimension", "$value": "{radius.lg}" },
    "radius-full": { "$type": "dimension", "$value": "{radius.full}" }
  },
  "elevation": {
    "$description": "コンポーネントの高さの度合い。全 theme 共通値（primitives.shadow の薄いラッパー）。",
    "raised":  { "$type": "shadow", "$value": "{shadow.level1}", "$description": "Card など基本の浮き" },
    "overlay": { "$type": "shadow", "$value": "{shadow.level2}", "$description": "Toast など一時的な浮き" },
    "modal":   { "$type": "shadow", "$value": "{shadow.level3}", "$description": "Dialog など最前面" }
  }
}
