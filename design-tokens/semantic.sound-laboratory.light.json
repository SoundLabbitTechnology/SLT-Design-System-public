{
  "$description": "SLT Design Tokens — Tier 2: Semantic(Sound Laboratory / ライトモード)。sound-laboratory-official-site DESIGN_SYSTEM.md / https://sound-laboratory.org/ 準拠。ゴールド・クリーム基調（coral は正式値保留）。",
  "color": {
    "surface": {
      "primary":   { "$type": "color", "$value": "{color.gray.0}", "$description": "base — 方眼紙グリッドの下地" },
      "secondary": { "$type": "color", "$value": "{color.gold.100}", "$description": "main #EAE1CF — カード・セクション面" },
      "tertiary":  { "$type": "color", "$value": "{color.gold.200}", "$description": "accent-1 #D9D2C1 — ボーダー・区切り" },
      "brand":     { "$type": "color", "$value": "{color.gold.500}", "$description": "semi-accent-1 — ブランドアクセント" },
      "inverse":   { "$type": "color", "$value": "{color.gray.900}" },
      "overlay":   { "$type": "color", "$value": "{color.alpha.slate-60}" }
    },
    "text": {
      "primary":   { "$type": "color", "$value": "{color.gray.900}" },
      "secondary": { "$type": "color", "$value": "{color.gray.600}" },
      "disabled":  { "$type": "color", "$value": "{color.gray.400}" },
      "inverse":   { "$type": "color", "$value": "{color.gray.0}" },
      "link":      { "$type": "color", "$value": "{color.gold.700}", "$description": "surface.primary/secondary 双方で 4.5:1 以上" },
      "link-hover": { "$type": "color", "$value": "{color.gold.800}", "$description": "gold.600 は白背景で 2.32:1 と 4.5:1 未達のため、hover も 4.5:1 を満たす色に変更" },
      "brand":     { "$type": "color", "$value": "{color.gold.700}", "$description": "本文サイズでの使用を想定し 4.5:1 を満たす値に統一" }
    },
    "border": {
      "default": { "$type": "color", "$value": "{color.gold.200}" },
      "strong":  { "$type": "color", "$value": "{color.gold.300}" },
      "focus":   { "$type": "color", "$value": "{color.gold.500}" }
    },
    "action": {
      "primary":         { "$type": "color", "$value": "{color.gold.500}", "$description": "primary CTA semi-accent-1" },
      "primary-hover":   { "$type": "color", "$value": "{color.gold.600}" },
      "primary-active":  { "$type": "color", "$value": "{color.gold.500}" },
      "secondary":       { "$type": "color", "$value": "{color.gold.300}", "$description": "accent-2 副 CTA" },
      "secondary-hover": { "$type": "color", "$value": "{color.gold.400}" }
    },
    "feedback": {
      "success":            { "$type": "color", "$value": "{color.emerald.500}" },
      "success-surface":    { "$type": "color", "$value": "{color.green.100}" },
      "success-on-surface": { "$type": "color", "$value": "{color.emerald.500}" },
      "warning":            { "$type": "color", "$value": "{color.amber.500}" },
      "warning-surface":    { "$type": "color", "$value": "{color.amber.100}" },
      "warning-on-surface": { "$type": "color", "$value": "{color.amber.500}" },
      "danger":             { "$type": "color", "$value": "{color.red.600}" },
      "danger-surface":     { "$type": "color", "$value": "{color.red.100}" },
      "danger-on-surface":  { "$type": "color", "$value": "{color.red.600}" },
      "info":               { "$type": "color", "$value": "{color.blue.600}" },
      "info-surface":       { "$type": "color", "$value": "{color.blue.50}" },
      "info-on-surface":    { "$type": "color", "$value": "{color.blue.600}" }
    },
    "interactive": {
      "hover":  { "$type": "color", "$value": "{color.gold.100}" },
      "active": { "$type": "color", "$value": "{color.gold.200}" }
    }
  },
  "typography": {
    "display": {
      "$type": "typography",
      "$value": { "fontFamily": "{font.family.display}", "fontSize": "{font.size.3xl}", "fontWeight": "{font.weight.bold}", "lineHeight": "{font.lineHeight.tight}" }
    },
    "heading-1": {
      "$type": "typography",
      "$value": { "fontFamily": "{font.family.display}", "fontSize": "{font.size.2xl}", "fontWeight": "{font.weight.bold}", "lineHeight": "{font.lineHeight.tight}" }
    },
    "heading-2": {
      "$type": "typography",
      "$value": { "fontFamily": "{font.family.jp}", "fontSize": "{font.size.xl}", "fontWeight": "{font.weight.bold}", "lineHeight": "{font.lineHeight.tight}" }
    },
    "heading-3": {
      "$type": "typography",
      "$value": { "fontFamily": "{font.family.jp}", "fontSize": "{font.size.lg}", "fontWeight": "{font.weight.medium}", "lineHeight": "{font.lineHeight.base}" }
    },
    "body": {
      "$type": "typography",
      "$value": { "fontFamily": "{font.family.jp}", "fontSize": "{font.size.md}", "fontWeight": "{font.weight.regular}", "lineHeight": "{font.lineHeight.relaxed}" }
    },
    "body-small": {
      "$type": "typography",
      "$value": { "fontFamily": "{font.family.jp}", "fontSize": "{font.size.sm}", "fontWeight": "{font.weight.regular}", "lineHeight": "{font.lineHeight.base}" }
    },
    "caption": {
      "$type": "typography",
      "$value": { "fontFamily": "{font.family.jp}", "fontSize": "{font.size.xs}", "fontWeight": "{font.weight.regular}", "lineHeight": "{font.lineHeight.tight}" }
    },
    "code": {
      "$type": "typography",
      "$value": { "fontFamily": "{font.family.mono}", "fontSize": "{font.size.sm}", "fontWeight": "{font.weight.regular}", "lineHeight": "{font.lineHeight.base}" }
    }
  },
  "focus": {
    "ring-width":  { "$type": "dimension", "$value": { "value": 2, "unit": "px" } },
    "ring-offset": { "$type": "dimension", "$value": { "value": 2, "unit": "px" } }
  },
  "space": {
    "$description": "レイアウト余白。全 theme 共通値（primitives.space の薄いラッパー）。",
    "xs": { "$type": "dimension", "$value": "{space.1}" },
    "sm": { "$type": "dimension", "$value": "{space.2}" },
    "md": { "$type": "dimension", "$value": "{space.4}" },
    "lg": { "$type": "dimension", "$value": "{space.6}" },
    "xl": { "$type": "dimension", "$value": "{space.8}" },
    "2xl": { "$type": "dimension", "$value": "{space.12}" }
  },
  "shape": {
    "$description": "角の形状。全 theme 共通値（primitives.radius の薄いラッパー）。",
    "radius-sm": { "$type": "dimension", "$value": "{radius.sm}" },
    "radius-md": { "$type": "dimension", "$value": "{radius.md}" },
    "radius-lg": { "$type": "dimension", "$value": "{radius.lg}" },
    "radius-full": { "$type": "dimension", "$value": "{radius.full}" }
  },
  "elevation": {
    "$description": "コンポーネントの高さの度合い。全 theme 共通値（primitives.shadow の薄いラッパー）。",
    "raised":  { "$type": "shadow", "$value": "{shadow.level1}", "$description": "Card など基本の浮き" },
    "overlay": { "$type": "shadow", "$value": "{shadow.level2}", "$description": "Toast など一時的な浮き" },
    "modal":   { "$type": "shadow", "$value": "{shadow.level3}", "$description": "Dialog など最前面" }
  }
}
