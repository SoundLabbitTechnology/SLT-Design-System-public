---
interface PropRow {
  name: string;
  type: string;
  default?: string;
  description: string;
}

interface Props {
  props: PropRow[];
}

const { props } = Astro.props;
---

{
  props.length > 0 ? (
    <div class="docs-token-table__wrap">
      <table class="docs-token-table">
        <thead>
          <tr>
            <th>Prop</th>
            <th>型</th>
            <th>デフォルト</th>
            <th>説明</th>
          </tr>
        </thead>
        <tbody>
          {props.map((p) => (
            <tr>
              <td>
                <code>{p.name}</code>
              </td>
              <td>
                <code>{p.type}</code>
              </td>
              <td>{p.default ? <code>{p.default}</code> : "—"}</td>
              <td>{p.description}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  ) : null
}
