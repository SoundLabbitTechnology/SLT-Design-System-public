---
import { getEntry, render } from "astro:content";
import DocLayout from "../../layouts/DocLayout.astro";
import { GUIDELINE_SLUGS, GUIDELINES, type GuidelineSlug } from "../../lib/nav";

export function getStaticPaths() {
  return GUIDELINE_SLUGS.map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params as { slug: GuidelineSlug };
const guideline = GUIDELINES[slug];
const entry = await getEntry("guidelines", guideline.id);
if (!entry) throw new Error(`${guideline.source} not found in guidelines collection`);
const { Content } = await render(entry);
---

<DocLayout title={guideline.title}>
  <div class="docs-prose">
    <Content />
  </div>
</DocLayout>
